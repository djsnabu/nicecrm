---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'NiceCRM' } = Astro.props;
---
<!doctype html>
<html lang="fi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme') || 'dark';
        document.documentElement.dataset.theme = t;
      })();
    </script>
  </head>
  <body>
    <!-- Beta banner -->
    <div class="bg-[var(--color-neon-magenta)]/15 border-b border-[var(--color-neon-magenta)]/30 text-center py-1.5 px-4 text-xs text-[var(--color-neon-magenta)]">
      NiceCRM v0.2.0 Beta — sovellus on kehitysvaiheessa
    </div>
    <slot />
    <!-- Bug report button -->
    <a
      href="mailto:asiakaspalvelu@kivamedia.fi?subject=NiceCRM%20bugi-ilmoitus&body=Kuvaa%20ongelma%20t%C3%A4h%C3%A4n%3A%0A%0A"
      class="fixed bottom-4 right-4 z-50 flex items-center gap-1.5 px-3 py-2 rounded-lg text-xs font-medium bg-amber-400/15 text-amber-400 border border-amber-400/30 hover:bg-amber-400/25 transition-colors shadow-lg backdrop-blur-sm"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      Ilmoita bugista
    </a>
  </body>
</html>
